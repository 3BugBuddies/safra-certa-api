                "url": {
                  "raw": "{{baseUrl}}/analise?talhaoId={{talhaoId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["analise"],
                  "query": [{ "key": "talhaoId", "value": "{{talhaoId}}", "description": "obrigatório" }]
                },
                "description": "Histórico completo de análises para gráfico de evolução do nível de risco."
              },
              "response": []
            }
          ]
        }
      ]
    },
