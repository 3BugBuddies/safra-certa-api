{
  "info": {
    "name": "SafraCerta API (estado atual)",
    "description": "Collection da SafraCerta API — PRD 02 (CRUD) + PRD 03 (ingestão de leitura + previsão Open-Meteo). Rotas no singular. Execute as pastas em ordem (1→5): os IDs criados são salvos em variáveis de collection e reutilizados. Motor de Risco/IA (PRD 04) ainda não exposto.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "cooperativaId", "value": "" },
    { "key": "produtorId", "value": "" },
    { "key": "culturaId", "value": "" },
    { "key": "talhaoId", "value": "" },
    { "key": "safraId", "value": "" },
    { "key": "dispositivoId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Setup base",
      "item": [
        {
          "name": "POST cooperativa",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.code === 201);",
              "pm.collectionVariables.set('cooperativaId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/cooperativa", "host": ["{{baseUrl}}"], "path": ["cooperativa"] },
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Cooperativa Sorriso\",\n  \"cnpj\": \"12345678000199\",\n  \"telefone\": \"6699990000\",\n  \"email\": \"contato@coop.com\",\n  \"logradouro\": \"Av. Brasil\",\n  \"numero\": \"1000\",\n  \"bairro\": \"Centro\",\n  \"cidade\": \"Sorriso\",\n  \"cep\": \"78890000\",\n  \"uf\": \"MT\"\n}" }
          }
        },
        {
          "name": "GET cooperativa (lista)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/cooperativa", "host": ["{{baseUrl}}"], "path": ["cooperativa"] }
          }
        },
        {
          "name": "POST produtor",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.code === 201);",
              "pm.collectionVariables.set('produtorId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/produtor", "host": ["{{baseUrl}}"], "path": ["produtor"] },
            "body": { "mode": "raw", "raw": "{\n  \"cooperativaId\": {{cooperativaId}},\n  \"nome\": \"João da Silva\",\n  \"telefone\": \"6698887777\",\n  \"cpf\": \"12345678901\",\n  \"nomePropriedade\": \"Fazenda Boa Vista\",\n  \"caf\": \"CAF-001\",\n  \"logradouro\": \"Rod. MT-242, km 10\",\n  \"numero\": \"S/N\",\n  \"bairro\": \"Zona Rural\",\n  \"cidade\": \"Sorriso\",\n  \"cep\": \"78890000\",\n  \"uf\": \"MT\"\n}" }
          }
        },
        {
          "name": "POST cultura",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.code === 201);",
              "pm.collectionVariables.set('culturaId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/cultura", "host": ["{{baseUrl}}"], "path": ["cultura"] },
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Soja\",\n  \"diasAteColheita\": 120,\n  \"umidadeSoloCritica\": 20.0,\n  \"temperaturaMinCritica\": 10.0,\n  \"temperaturaMaxCritica\": 35.0,\n  \"chuvaMinima\": 5.0\n}" }
          }
        },
        {
          "name": "POST talhao",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.code === 201);",
              "pm.collectionVariables.set('talhaoId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/talhao", "host": ["{{baseUrl}}"], "path": ["talhao"] },
            "body": { "mode": "raw", "raw": "{\n  \"produtorId\": {{produtorId}},\n  \"nome\": \"Talhão Norte\",\n  \"areaHa\": 50.0,\n  \"centro\": { \"latitude\": -12.5455, \"longitude\": -55.7215 },\n  \"pontos\": [\n    { \"ordem\": 1, \"latitude\": -12.544, \"longitude\": -55.722 },\n    { \"ordem\": 2, \"latitude\": -12.546, \"longitude\": -55.722 },\n    { \"ordem\": 3, \"latitude\": -12.546, \"longitude\": -55.720 }\n  ]\n}" }
          }
        },
        {
          "name": "POST safra",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.code === 201);",
              "pm.collectionVariables.set('safraId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/safra", "host": ["{{baseUrl}}"], "path": ["safra"] },
            "body": { "mode": "raw", "raw": "{\n  \"talhaoId\": {{talhaoId}},\n  \"culturaId\": {{culturaId}},\n  \"dataPlantio\": \"2026-03-01\",\n  \"dataPrevistaColheita\": \"2026-07-01\",\n  \"statusSafra\": \"ATIVA\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2. Dispositivo",
      "item": [
        {
          "name": "POST dispositivo",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('201', () => pm.response.code === 201);",
              "pm.collectionVariables.set('dispositivoId', pm.response.json().id);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/dispositivo", "host": ["{{baseUrl}}"], "path": ["dispositivo"] },
            "body": { "mode": "raw", "raw": "{\n  \"codigoDispositivo\": \"ESP-001\",\n  \"talhaoId\": {{talhaoId}},\n  \"ativo\": true\n}" }
          }
        },
        {
          "name": "GET dispositivo (lista)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/dispositivo", "host": ["{{baseUrl}}"], "path": ["dispositivo"] }
          }
        },
        {
          "name": "GET dispositivo/{id}",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/dispositivo/{{dispositivoId}}", "host": ["{{baseUrl}}"], "path": ["dispositivo", "{{dispositivoId}}"] }
          }
        },
        {
          "name": "PUT dispositivo (atualizar/ativar)",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/dispositivo/{{dispositivoId}}", "host": ["{{baseUrl}}"], "path": ["dispositivo", "{{dispositivoId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"codigoDispositivo\": \"ESP-001\",\n  \"talhaoId\": {{talhaoId}},\n  \"ativo\": true\n}" }
          }
        },
        {
          "name": "POST dispositivo duplicado (409 — 1 por talhão)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('409', () => pm.response.code === 409);" ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/dispositivo", "host": ["{{baseUrl}}"], "path": ["dispositivo"] },
            "body": { "mode": "raw", "raw": "{\n  \"codigoDispositivo\": \"ESP-002\",\n  \"talhaoId\": {{talhaoId}},\n  \"ativo\": true\n}" }
          }
        }
      ]
    },
    {
      "name": "3. Leitura",
      "item": [
        {
          "name": "POST leitura (201 + dispara previsão)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('201', () => pm.response.code === 201);" ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/leitura", "host": ["{{baseUrl}}"], "path": ["leitura"] },
            "body": { "mode": "raw", "raw": "{\n  \"codigoDispositivo\": \"ESP-001\",\n  \"dataHora\": \"2026-06-05T14:30:00\",\n  \"temperatura\": 28.5,\n  \"umidadeAr\": 65.0,\n  \"umidadeSolo\": 30.0,\n  \"radiacaoSolar\": 800.0\n}" }
          }
        },
        {
          "name": "GET leitura?talhaoId",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/leitura?talhaoId={{talhaoId}}", "host": ["{{baseUrl}}"], "path": ["leitura"], "query": [ { "key": "talhaoId", "value": "{{talhaoId}}" } ] }
          }
        },
        {
          "name": "POST leitura fora de faixa (400)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('400', () => pm.response.code === 400);" ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/leitura", "host": ["{{baseUrl}}"], "path": ["leitura"] },
            "body": { "mode": "raw", "raw": "{\n  \"codigoDispositivo\": \"ESP-001\",\n  \"dataHora\": \"2026-06-05T14:30:00\",\n  \"temperatura\": 99.0,\n  \"umidadeAr\": 65.0,\n  \"umidadeSolo\": 30.0,\n  \"radiacaoSolar\": 800.0\n}" }
          }
        }
      ]
    },
    {
      "name": "4. Previsão (Open-Meteo)",
      "item": [
        {
          "name": "GET previsao?talhaoId",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/previsao?talhaoId={{talhaoId}}", "host": ["{{baseUrl}}"], "path": ["previsao"], "query": [ { "key": "talhaoId", "value": "{{talhaoId}}" } ] }
          }
        }
      ]
    },
    {
      "name": "5. Erros",
      "item": [
        {
          "name": "GET produtor inexistente (404)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('404', () => pm.response.code === 404);" ] } }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/produtor/999999", "host": ["{{baseUrl}}"], "path": ["produtor", "999999"] }
          }
        },
        {
          "name": "POST cooperativa vazia (400)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('400', () => pm.response.code === 400);" ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/cooperativa", "host": ["{{baseUrl}}"], "path": ["cooperativa"] },
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    }
  ]
}
